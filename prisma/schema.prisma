generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  reviews   Review[]
}

model Review {
  id               String   @id @default(cuid())

  code             String
  language         String

  score            Int
  summary          String

  timeComplexity   String
  spaceComplexity  String

  bugs             Json
  codeSmells        Json?
  suggestions      Json
  improvedCode     String

  createdAt        DateTime @default(now())

  userId           String
  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)
}