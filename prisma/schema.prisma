generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  reviews   Review[]
}

model Review {
  id         String   @id @default(cuid())
  language   String
  sourceCode String
  aiFeedback String?
  score      Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
